#!/usr/bin/env bash
set -e
test -z "${DEBUG}" || set -x

##
# parameters
opts="Dhdes:"
divider=false
exitOnError=false
seconds=5

function usage {
  cat << _usage_
  $(basename "$0"): repeat a command ad infinitum

  usage:
    $(basename "$0") [-$opts] <command...>

    D - turn on debug mode.
    h - you are here.
    d - print a divider between iterations.
    e - exit on error.
    s - seconds between iterations (default: $seconds).
_usage_
}

while getopts $opts opt; do
  case $opt in
    D)   DEBUG=true; set -x                          ;;
    h)   usage; exit                                 ;;
    d)   divider=true                                ;;
    e)   exitOnError=true                            ;;
    s)   test -n "$OPTARG" && seconds="$OPTARG"      ;;
    ?|*) echo; usage; exit 5                         ;;
  esac
done
shift $((OPTIND-1))
##


##
# main
test -n "$*" || { echo "supply a command to loop" >&2; exit 1; }

echo "looping { $*; } every $seconds seconds; CTRL+C to quit."

while :
do
  { "$@"; }
  code=$?

  $exitOnError && { test $code = 0 || break; }

  sleep "$seconds"

  $divider && echo "-----"
done
##
