[user]
  name = <NAME>
  email = <EMAIL>
  signingkey = <SIGNING_KEY>
[core]
  whitespace = trailing-space
  autocrlf = input
  excludesfile = ~/.gitignore
[commit]
  gpgSign = true
[init]
  defaultBranch = main
[alias]
  unstage = reset HEAD --
  last = log -1 HEAD
  st = status
  co = commit -S
  br = branch
  hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
  type = cat-file -t
  dump = cat-file -p
[color]
  ui = true
[color "diff"]
  new = white
[url "git@github.com:"]
  insteadOf = https://github.com/
[gpg]
  program = gpg
[github]
  user = <GITHUB_USER>
